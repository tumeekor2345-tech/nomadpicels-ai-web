# Copy this file to `.env.local` (which Git ignores) and fill in real values.
# Never commit real secrets — this file only holds placeholders.

# --- Clerk authentication ---
# Get these from https://dashboard.clerk.com after creating an app.
# Remember to enable "Organizations" in Clerk Dashboard > Organization management > Settings.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=REPLACE_WITH_YOUR_CLERK_SECRET_KEY

# --- Database (production) ---
# Local dev uses PGlite automatically, no value needed until you deploy.
# For production, e.g. a free Neon Postgres: https://neon.tech
DATABASE_URL=postgresql://user:password@host:5432/nomadpixels

# --- App ---
NEXT_PUBLIC_APP_URL=https://nomadpixels-ai.com

# --- RunPod (Flux image gen + Wan 2.2 video gen) ---
# https://www.runpod.io -> Settings -> API Keys
RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Serverless -> your endpoint -> copy the Endpoint ID (not the name)
RUNPOD_FLUX_ENDPOINT_ID=xxxxxxxxxxxxxxxx
RUNPOD_WAN_ENDPOINT_ID=xxxxxxxxxxxxxxxx
# "Tools" -> Face Swap. Deploy the `runpod/comfyui-faceswap-sdxl` image as a
# new Serverless Endpoint (32GB+ VRAM GPU), then paste its Endpoint ID here.
# See https://github.com/runpod-workers/comfyui-faceswap-sdxl
RUNPOD_FACESWAP_ENDPOINT_ID=xxxxxxxxxxxxxxxx

# --- QPay (Merchant V2 API) ---
# https://developer.qpay.mn -> apply for merchant credentials
# Use the sandbox URL until QPay approves production access.
QPAY_BASE_URL=https://merchant-sandbox.qpay.mn
QPAY_CLIENT_ID=xxxxxxxxxxxxxxxx
QPAY_CLIENT_SECRET=xxxxxxxxxxxxxxxx
QPAY_INVOICE_CODE=xxxxxxxxxxxxxxxx

# --- SocialPay / Bank card gateway (Phase 2 — leave unset for MVP) ---
# SOCIALPAY_MERCHANT_ID=
# SOCIALPAY_API_KEY=

# --- Logging (optional) ---
NEXT_PUBLIC_LOGGING_LEVEL=debug

# --- Admin dashboard (/dashboard/admin, optional) ---
# Comma-separated Clerk account emails allowed to view the admin page.
# src/libs/Admin.ts also has a hardcoded fallback owner email, so this is
# only needed if you want to grant additional admins.
ADMIN_EMAILS=owner@example.com
